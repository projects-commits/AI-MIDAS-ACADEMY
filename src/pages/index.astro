---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import CategoryBadge from "../components/ui/CategoryBadge.astro";
import categoriesData from "../data/categories.json";
import type { Category } from "../types";
import image1Academy from "../../resources/imagem1_academy.png";
import image2Academy from "../../resources/imagem2_academy.png";
import image3Academy from "../../resources/imagem3_academy.png";
import image4Academy from "../../resources/imagem4_academy.png";
import image5Academy from "../../resources/imagem5_academy.png";
import image6Academy from "../../resources/imagem6_academy.png";

const categories = categoriesData as Category[];

const sliderCards = [
  { src: image1Academy, alt: "Card 1 da AI MIDAS Academy" },
  { src: image2Academy, alt: "Card 2 da AI MIDAS Academy" },
  { src: image3Academy, alt: "Card 3 da AI MIDAS Academy" },
  { src: image4Academy, alt: "Card 4 da AI MIDAS Academy" },
  { src: image5Academy, alt: "Card 5 da AI MIDAS Academy" },
  { src: image6Academy, alt: "Card 6 da AI MIDAS Academy" }
];

const academySignals = [
  {
    index: "01",
    title: "Acesso aberto",
    description:
      "Todos os cursos da academia são gratuitos e públicos, para tornar este tipo de conhecimento mais acessível e menos dependente de ruído comercial."
  },
  {
    index: "02",
    title: "Profundidade real",
    description:
      "Cada tema é trabalhado com mecanismos, exemplos, failure modes, checklists e ligação clara entre teoria, leitura de mercado e decisão."
  },
  {
    index: "03",
    title: "Visão integrada",
    description:
      "A aprendizagem cruza price, probability, risk, context, research e prediction markets para construir critério em várias frentes, não apenas opinião isolada."
  },
  {
    index: "04",
    title: "Decisão melhor",
    description:
      "O objetivo não é aumentar confiança teatral, mas melhorar a qualidade da leitura, da avaliação e da decisão de quem investe tempo e capital nestes mercados."
  }
];
---

<BaseLayout
  title="Home"
  description="Cursos gratuitos e inteligência preditiva para estudar futebol com mais critério."
  hideTopBar={true}
>
  <div class="promo-banner" data-home-promo>
    <div class="promo-banner__inner">
      <p class="promo-banner__copy">
        Aprenda fazendo. Inscrições abertas:
        <strong>Framework 9 Passos para Análise de um Jogo de Futebol.</strong>
      </p>
      <a class="promo-banner__cta" href="/courses/framework-de-9-passos-para-analisar-um-jogo-de-futebol/">
        Entrar no curso
      </a>
      <button class="promo-banner__close" type="button" aria-label="Fechar aviso" data-home-promo-close>
        ×
      </button>
    </div>
  </div>

  <section class="home-hero">
    <Container size="wide">
      <div class="home-hero__inner">
        <h1 class="home-hero__title">
          <span class="home-hero__line">
            A <span class="home-hero__highlight">Primeira</span> Plataforma <span class="home-hero__highlight">Gratuita</span>
          </span>
          <span class="home-hero__line">
            para <span class="home-hero__accent">Inteligência Preditiva.</span>
          </span>
        </h1>

        <div class="home-hero__actions">
          <a class="button-primary" href="/courses/">Explorar cursos gratuitos</a>
        </div>
      </div>

      <div class="home-marquee">
        <div class="home-marquee__track">
          <div class="home-marquee__group">
            {
              sliderCards.map((card) => (
                <article class="home-marquee-card">
                  <img
                    class="home-marquee-card__image"
                    src={card.src.src}
                    width={card.src.width}
                    height={card.src.height}
                    alt={card.alt}
                    loading="lazy"
                    decoding="async"
                  />
                </article>
              ))
            }
          </div>

          <div class="home-marquee__group" aria-hidden="true">
            {
              sliderCards.map((card) => (
                <article class="home-marquee-card">
                  <img
                    class="home-marquee-card__image"
                    src={card.src.src}
                    width={card.src.width}
                    height={card.src.height}
                    alt={card.alt}
                    loading="lazy"
                    decoding="async"
                  />
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </Container>
  </section>

  <Container>
    <section id="como-funciona" class="home-proof">
      <p class="home-section__eyebrow">Entrada na academia</p>
      <h2>
        O que encontras aqui <span>desde o primeiro dia</span>.
      </h2>
      <p class="home-section__intro">
        Ainda não mostramos números de vaidade nem testemunhos fabricados. Mostramos a estrutura da
        academia, a profundidade do estudo e a razão pela qual este projeto existe: formar leitores
        mais preparados para pensar, avaliar e decidir melhor.
      </p>

      <div class="home-proof__grid">
        {
          academySignals.map((signal) => (
            <article class="home-proof__card">
              <div class="home-proof__icon" aria-hidden="true">{signal.index}</div>
              <h3>{signal.title}</h3>
              <p>{signal.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="home-areas">
      <div class="home-section-heading">
        <p class="home-section__eyebrow">Várias áreas de estudo</p>
        <h2>
          Uma academia para aprender <span>mercado</span> a partir de
          <span> vários ângulos</span>.
        </h2>
        <p class="home-section__intro">
          Os cursos não vivem numa única narrativa. A estrutura cruza leitura de jogo, leitura de
          mercado, modelagem, risco e execução.
        </p>
      </div>

      <div class="home-areas__grid">
        {
          categories.map((category) => (
            <article class="home-area-card">
              <div class="home-area-card__top">
                <CategoryBadge label={category.name} />
              </div>
              <h3>{category.name}</h3>
              <p>{category.summary}</p>
              <small>{category.angle}</small>
            </article>
          ))
        }
      </div>
    </section>

    <section class="home-final-cta">
      <div class="home-final-cta__panel">
        <p class="home-section__eyebrow">AI MIDAS ACADEMY</p>
        <h2>
          Começar a Aprender com <span>Processo</span>
        </h2>
        <p>
          Cursos públicos, profundos e pensados para quem quer mais conhecimento antes de mais
          convicção.
        </p>
        <a class="button-primary" href="/courses/">Explorar cursos gratuitos</a>
      </div>
    </section>
  </Container>

  <script is:inline>
    const storageKey = "ai-midas-home-promo-dismissed";
    const banner = document.querySelector("[data-home-promo]");
    const closeButton = document.querySelector("[data-home-promo-close]");

    if (banner && localStorage.getItem(storageKey) === "true") {
      banner.setAttribute("hidden", "");
    }

    closeButton?.addEventListener("click", () => {
      banner?.setAttribute("hidden", "");
      localStorage.setItem(storageKey, "true");
    });
  </script>
</BaseLayout>

<style>
  .promo-banner {
    position: sticky;
    top: 0;
    z-index: 40;
    background: #ff4500;
    color: #fff7f0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.12);
  }

  .promo-banner[hidden] {
    display: none;
  }

  .promo-banner__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 1rem;
    width: min(1320px, calc(100% - 1.5rem));
    margin: 0 auto;
    padding: 0.85rem 0;
  }

  .promo-banner__copy {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.4;
  }

  .promo-banner__copy strong {
    color: #fff1b8;
  }

  .promo-banner__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0.8rem 1.2rem;
    border-radius: 999px;
    background: #121212;
    color: #ffffff;
    font-family: var(--font-brand);
    font-weight: 700;
    white-space: nowrap;
  }

  .promo-banner__close {
    width: 2.6rem;
    height: 2.6rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: #fff7f0;
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
  }

  .home-hero {
    overflow: hidden;
    padding: 1.6rem 0 3rem;
    background:
      radial-gradient(circle at 50% 0%, rgba(255, 215, 0, 0.13), transparent 28%),
      radial-gradient(circle at 12% 22%, rgba(255, 69, 0, 0.18), transparent 24%),
      linear-gradient(180deg, #151515 0%, #101010 52%, #0d0d0d 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .home-hero__inner {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1rem;
    width: fit-content;
    margin: 0 auto;
    padding: 2.2rem 0 1.8rem;
  }

  .home-section__eyebrow {
    margin: 0;
    color: var(--color-secondary);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .home-hero__title,
  .home-proof h2,
  .home-section-heading h2,
  .home-final-cta__panel h2 {
    margin: 0;
    font-family: var(--font-brand);
    line-height: 1.02;
  }

  .home-hero__title {
    display: grid;
    justify-items: center;
    gap: 0.08em;
    width: 100%;
    font-size: clamp(1.9rem, 4.4vw, 3.45rem);
    line-height: 1.1;
    margin: 0 auto;
  }

  .home-hero__line {
    display: block;
    white-space: nowrap;
    text-align: center;
  }

  .home-hero__highlight {
    color: #ffd700;
  }

  .home-hero__accent {
    color: #ff4500;
  }

  .home-section__intro,
  .home-final-cta__panel p {
    margin: 0;
    max-width: 70ch;
    color: var(--color-muted);
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
    margin-top: 0.35rem;
  }

  .home-marquee {
    margin-top: 2rem;
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .home-marquee__track {
    display: flex;
    width: max-content;
    animation: home-marquee-scroll 34s linear infinite;
    will-change: transform;
  }

  .home-marquee:hover .home-marquee__track {
    animation-play-state: paused;
  }

  .home-marquee__group {
    display: flex;
    gap: 1rem;
    padding-right: 1rem;
  }

  .home-marquee-card {
    width: 340px;
    min-width: 340px;
    padding: 0.45rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
      #111111;
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.34);
    overflow: hidden;
  }

  .home-marquee-card__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 19px;
    border: 1px solid rgba(255, 215, 0, 0.16);
  }

  .home-proof,
  .home-areas,
  .home-final-cta {
    padding-top: 4rem;
  }

  .home-proof {
    text-align: center;
  }

  .home-proof h2,
  .home-section-heading h2,
  .home-final-cta__panel h2 {
    font-size: clamp(2rem, 4vw, 3.4rem);
  }

  .home-proof h2 span,
  .home-section-heading h2 span,
  .home-final-cta__panel h2 span {
    color: #ffd700;
  }

  .home-proof h2,
  .home-proof .home-section__intro,
  .home-section-heading,
  .home-final-cta__panel {
    margin-left: auto;
    margin-right: auto;
  }

  .home-proof__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .home-proof__card,
  .home-area-card,
  .home-final-cta__panel {
    border: 1px solid var(--color-border);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
      #141414;
    box-shadow: var(--shadow-soft);
  }

  .home-proof__card {
    display: grid;
    justify-items: center;
    gap: 0.9rem;
    padding: 1.5rem 1.15rem;
    text-align: center;
    background:
      radial-gradient(circle at top center, rgba(255, 215, 0, 0.08), transparent 38%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
      #181818;
  }

  .home-proof__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.3rem;
    height: 3.3rem;
    border: 1px solid rgba(255, 215, 0, 0.24);
    border-radius: 50%;
    background: rgba(255, 215, 0, 0.08);
    color: var(--color-secondary);
    font-weight: 700;
    box-shadow: 0 0 0 1px rgba(255, 69, 0, 0.08);
  }

  .home-proof__card h3,
  .home-area-card h3 {
    margin: 0;
    font-family: var(--font-brand);
    font-size: 1.2rem;
  }

  .home-proof__card p,
  .home-area-card p {
    margin: 0;
    color: var(--color-muted);
  }

  .home-section-heading {
    display: grid;
    gap: 0.65rem;
    max-width: 62rem;
  }

  .home-areas__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.8rem;
  }

  .home-area-card {
    display: grid;
    gap: 0.9rem;
    padding: 1.25rem;
    background:
      radial-gradient(circle at top right, rgba(255, 69, 0, 0.1), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
      #181818;
  }

  .home-area-card__top {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .home-area-card small {
    color: var(--color-secondary);
    font-size: 0.94rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .home-final-cta {
    padding-bottom: 1rem;
  }

  .home-final-cta__panel {
    display: grid;
    justify-items: center;
    gap: 1rem;
    padding: 2.2rem 1.4rem;
    text-align: center;
    background:
      radial-gradient(circle at top center, rgba(255, 215, 0, 0.1), transparent 32%),
      radial-gradient(circle at 12% 50%, rgba(255, 69, 0, 0.08), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
      #141414;
  }

  @keyframes home-marquee-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-marquee__track {
      animation: none;
    }

    .home-marquee {
      overflow-x: auto;
      mask-image: none;
    }
  }

  @media (max-width: 1100px) {
    .promo-banner__inner,
    .home-proof__grid,
    .home-areas__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .promo-banner__inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .promo-banner__close {
      grid-column: 2;
      grid-row: 1 / span 2;
      align-self: start;
    }
  }

  @media (max-width: 820px) {
    .home-hero {
      padding-top: 1.1rem;
    }

    .home-hero__title {
      font-size: clamp(1.9rem, 7vw, 3rem);
    }

    .promo-banner__inner,
    .home-proof__grid,
    .home-areas__grid {
      grid-template-columns: 1fr;
    }

    .promo-banner__cta {
      justify-self: start;
    }

    .promo-banner__close {
      position: absolute;
      top: 0.5rem;
      right: 0.75rem;
    }

    .promo-banner__inner {
      position: relative;
      padding-right: 3.5rem;
    }

    .home-proof,
    .home-areas,
    .home-final-cta {
      padding-top: 3rem;
    }
  }

  @media (max-width: 680px) {
    .home-hero__actions {
      width: 100%;
    }

    .home-hero__actions :global(.button-primary),
    .home-final-cta__panel :global(.button-primary),
    .promo-banner__cta {
      width: 100%;
      justify-content: center;
    }

    .home-marquee {
      margin-top: 1rem;
      mask-image: none;
    }

    .home-marquee-card {
      width: 280px;
      min-width: 280px;
    }
  }

  @media (max-width: 480px) {
    .home-hero__line {
      white-space: normal;
    }

    .home-hero {
      padding: 1rem 0 2rem;
    }

    .home-hero__inner {
      padding: 1.4rem 0 1.2rem;
    }

    .home-hero__title {
      font-size: clamp(1.6rem, 7.5vw, 2.2rem);
    }

    .home-marquee-card {
      width: 240px;
      min-width: 240px;
      padding: 0.35rem;
      border-radius: 18px;
    }

    .home-marquee-card__image {
      border-radius: 14px;
    }

    .home-proof__card,
    .home-area-card {
      padding: 1.1rem 1rem;
      border-radius: 18px;
    }

    .home-proof__icon {
      width: 2.8rem;
      height: 2.8rem;
    }

    .home-proof__card h3,
    .home-area-card h3 {
      font-size: 1.1rem;
    }

    .home-final-cta__panel {
      padding: 1.6rem 1rem;
      border-radius: 18px;
    }

    .promo-banner__inner {
      padding: 0.75rem 0;
    }

    .promo-banner__copy {
      font-size: 0.9rem;
    }
  }
</style>
