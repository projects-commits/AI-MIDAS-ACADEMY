---
import type { SiteData } from "../../types";
import logoAiMidas from "../../../logofinal_aimidas.png";
import { getCourseHref } from "../../lib/course";
import { defaultLocale, localizedPath, type AppLocale } from "../../i18n/config";
import { getDictionary } from "../../i18n/ui";

interface Props {
  site: SiteData;
  locale?: AppLocale;
}

const { site, locale = defaultLocale } = Astro.props;
const dictionary = getDictionary(locale);
const currentPath = Astro.url.pathname;
---

<header class="site-topbar">
  <div class="topbar-promo">
    <div class="topbar-promo__inner">
      <a class="topbar-promo__brand" href={localizedPath(locale, "/")} aria-label="AI MIDAS ACADEMY">
        <img
          class="topbar-promo__logo"
          src={logoAiMidas.src}
          width={logoAiMidas.width}
          height={logoAiMidas.height}
          alt="Logo AI MIDAS ACADEMY"
        />
      </a>

      <span class="topbar-promo__divider" aria-hidden="true"></span>

      <p class="topbar-promo__copy">{site.tagline}</p>

      <a class="topbar-promo__cta" href={getCourseHref("framework-de-9-passos-para-analisar-um-jogo-de-futebol", locale)}>
        {dictionary.site.promoCta}
      </a>
    </div>
  </div>

  <div class="topbar-main">
    <div class="topbar__inner">
      <a class="brand-lockup" href={localizedPath(locale, "/")}>
        <span class="brand-lockup__name">{site.name}</span>
      </a>

      <nav class="topbar__nav" aria-label="Primary">
        {
          site.navigation.map((item) => (
            <a
              href={localizedPath(locale, item.href)}
              class:list={[
                "topbar__link",
                currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
                  ? "is-active"
                  : ""
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>
