# Variáveis de ambiente do AI MIDAS ACADEMY
# Nunca commites o ficheiro .env real — mantém-se apenas localmente.

# Configuração do site (ex: nome do repo para base path no GitHub Pages)
# GITHUB_PAGES_BASE=/nome-do-repo

# Dados do repositório do curso (para sincronização e workflow)
COURSE_REPO_URL=https://github.com/USER/curso-ai-midas-framework.git

# (Opcional) Token de acesso pessoal para repo privado do curso
# COURSE_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# (Opcional) API key se algum dia precisares de backend/função serverless
# API_KEY=
