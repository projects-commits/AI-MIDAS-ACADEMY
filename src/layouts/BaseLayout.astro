---
import "../styles/global.css";
import TopBar from "../components/academy/TopBar.astro";
import Footer from "../components/academy/Footer.astro";
import { getSiteData } from "../i18n/ui";
import { defaultLocale, type AppLocale } from "../i18n/config";

interface Props {
  locale?: AppLocale;
  title?: string;
  description?: string;
  hideTopBar?: boolean;
  ogImage?: string;
  canonical?: string;
}

const { locale = defaultLocale, title, description, hideTopBar = false, ogImage, canonical } = Astro.props;
const siteData = getSiteData(locale);
const siteName = siteData.name;
const pageTitle = title ? `${title} | ${siteName}` : siteName;
const pageDescription = description ?? siteData.description;
const pageUrl = canonical ?? Astro.url.href;
const defaultOgImage = ogImage ?? "/assets/images/og-default.png";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#121212" />
    <meta name="google-site-verification" content="xk9cKa12ydi3CVHz4DkSrNBa5eRQnKD9wz3pNmK-urA" />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={new URL(defaultOgImage, pageUrl).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {import.meta.env.PUBLIC_GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`} is:inline></script>
        <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body>
    <div class="site-frame">
      {!hideTopBar && <TopBar site={siteData} locale={locale} />}
      <main class="page-shell">
        <slot />
      </main>
      <Footer site={siteData} locale={locale} />
    </div>
  </body>
</html>
