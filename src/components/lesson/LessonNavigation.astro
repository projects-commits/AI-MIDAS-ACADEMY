---
import type { CourseLesson } from "../../types";
import { getLessonHref } from "../../lib/course";
import { type AppLocale } from "../../i18n/config";
import { getDictionary } from "../../i18n/ui";

interface Props {
  courseSlug: string;
  previousLesson: CourseLesson | null;
  nextLesson: CourseLesson | null;
  locale: AppLocale;
}

const { courseSlug, previousLesson, nextLesson, locale } = Astro.props;
const dictionary = getDictionary(locale);
---

<nav class="lesson-navigation" aria-label="Navegacao da aula">
  {previousLesson ? (
    <a class="lesson-navigation__link" href={getLessonHref(courseSlug, previousLesson.slug, locale)}>
      <span>{dictionary.lesson.previousLesson}</span>
      <strong>{previousLesson.title}</strong>
    </a>
  ) : (
    <div class="lesson-navigation__link is-empty">
      <span>{dictionary.lesson.previousLesson}</span>
      <strong>{dictionary.lesson.startOfCourse}</strong>
    </div>
  )}

  {nextLesson ? (
    <a class="lesson-navigation__link" href={getLessonHref(courseSlug, nextLesson.slug, locale)}>
      <span>{dictionary.lesson.nextLesson}</span>
      <strong>{nextLesson.title}</strong>
    </a>
  ) : (
    <div class="lesson-navigation__link is-empty">
      <span>{dictionary.lesson.nextLesson}</span>
      <strong>{dictionary.lesson.endOfCurrentPath}</strong>
    </div>
  )}
</nav>

