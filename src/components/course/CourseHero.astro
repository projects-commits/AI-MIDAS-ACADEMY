---
import CategoryBadge from "../ui/CategoryBadge.astro";
import type { CourseData } from "../../types";
import { formatCategoryName, formatLevel } from "../../lib/course";
import heroBg from "../../../hero_course_9_passos.png";
import { type AppLocale } from "../../i18n/config";
import { getDictionary } from "../../i18n/ui";

interface Props {
  course: CourseData;
  firstLessonHref: string;
  locale: AppLocale;
}

const { course, firstLessonHref, locale } = Astro.props;
const dictionary = getDictionary(locale);
---

<section class="course-hero" style={`background-image: url(${heroBg.src})`}>
  <div class="course-hero__overlay" aria-hidden="true"></div>
  <div class="course-hero__main">
    <p class="gold-label">{dictionary.course.publishedCourse}</p>
    <h1>{course.title}</h1>
    <p class="course-hero__subtitle">{course.subtitle}</p>
    <p class="course-hero__promise">{course.corePromise}</p>

    <div class="course-hero__meta">
      <CategoryBadge label={formatCategoryName(course.category, locale)} />
      <span class="meta-pill">{formatLevel(course.level, locale)}</span>
      <span class="meta-pill">{course.estimatedReadingMinutes} {dictionary.shared.minutes}</span>
      <span class="meta-pill">{dictionary.course.modules(course.courseStats.moduleCount)}</span>
      <span class="meta-pill">{dictionary.course.lessons(course.courseStats.lessonCount)}</span>
    </div>

    <div class="course-hero__actions">
      <a class="button-primary" href={firstLessonHref}>{dictionary.course.startCourse}</a>
    </div>
  </div>
</section>
