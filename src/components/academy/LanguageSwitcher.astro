---
import { localeLabels, locales, localizedPath, type AppLocale } from "../../i18n/config";
import { getDictionary } from "../../i18n/ui";

interface Props {
  locale: AppLocale;
  pathname: string;
  variant?: "topbar" | "floating";
}

const { locale, pathname, variant = "topbar" } = Astro.props;
const dictionary = getDictionary(locale);
const links = locales.map((item) => ({
  locale: item,
  label: localeLabels[item],
  href: localizedPath(item, pathname)
}));
---

<nav class:list={["language-switcher", `language-switcher--${variant}`]} aria-label={dictionary.site.localeSwitcherLabel}>
  <span class="language-switcher__label">{dictionary.site.localeSwitcherLabel}</span>
  <div class="language-switcher__links">
    {
      links.map((item) => (
        <a
          href={item.href}
          class:list={["language-switcher__link", item.locale === locale && "is-active"]}
          data-locale-link
          data-locale={item.locale}
          lang={item.locale}
        >
          {item.label}
        </a>
      ))
    }
  </div>
</nav>

<script is:inline>
  const localeLinks = document.querySelectorAll("[data-locale-link]");

  localeLinks.forEach((link) => {
    link.addEventListener("click", () => {
      const locale = link.getAttribute("data-locale");

      if (locale) {
        localStorage.setItem("ai-midas-locale", locale);
      }
    });
  });
</script>
