---
import type { CourseData } from "../../types";
import { getLessonHref, getLessonsForModule } from "../../lib/course";
import { type AppLocale } from "../../i18n/config";
import { getDictionary } from "../../i18n/ui";

interface Props {
  course: CourseData;
  locale: AppLocale;
}

const { course, locale } = Astro.props;
const dictionary = getDictionary(locale);
---

<section class="course-curriculum" id="curriculo">
  <div class="section-header">
    <p class="gold-label">{dictionary.course.curriculum}</p>
    <h2>{dictionary.course.curriculumTitle}</h2>
    <p class="section-intro">{dictionary.course.curriculumIntro}</p>
  </div>

  <div class="curriculum-modules">
    {
      course.modules.map((module, index) => (
        <article class="terminal-card curriculum-module">
          <div class="curriculum-module__header">
            <div>
              <p class="gold-label">{dictionary.course.moduleLabel(index + 1)}</p>
              <h3>{module.title}</h3>
            </div>
            <span class="course-badge">{dictionary.course.lessonCount(module.lessonIds.length)}</span>
          </div>

          <p class="muted-copy">{module.summary}</p>

          <div class="curriculum-lessons">
            {getLessonsForModule(course, module).map((lesson) => (
              <a
                class="curriculum-lesson"
                href={getLessonHref(course.slug, lesson.slug, locale)}
                data-lesson-item
                data-course-id={course.id}
                data-lesson-id={lesson.id}
              >
                <span class="curriculum-lesson__number">{dictionary.course.lessonLabel(lesson.lessonNumber)}</span>
                <strong>{lesson.title}</strong>
                <span class="muted-copy">{lesson.readingMinutes} {dictionary.shared.minutes}</span>
              </a>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</section>
