---
interface Props {
  title: string;
  summary?: string;
}

const { title, summary } = Astro.props;
---

<article class="terminal-card failure-card" data-motion-reveal>
  <p class="gold-label">Modo de falha</p>
  <h3>{title}</h3>
  {summary ? <p class="muted-copy">{summary}</p> : <div class="failure-card__body"><slot /></div>}
</article>
